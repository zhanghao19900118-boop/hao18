#!/usr/bin/env bash
set -Eeuo pipefail
APP_DIR="${APP_DIR:-/opt/worldcup}"
BRANCH="${BRANCH:-main}"
sudo /usr/local/bin/backup-worldcup
git -C "$APP_DIR" fetch origin "$BRANCH"
git -C "$APP_DIR" checkout "$BRANCH"
git -C "$APP_DIR" pull --ff-only origin "$BRANCH"
cd "$APP_DIR"
npm ci --omit=dev
sudo -u worldcup env DB_PATH=/var/lib/worldcup/worldcup.db npm run migrate
sudo systemctl restart worldcup
sleep 2
curl -fsS http://127.0.0.1:3000/api/health >/dev/null
sudo nginx -t
sudo systemctl reload nginx
echo "V3 已更新到 $BRANCH，并通过健康检查。"
